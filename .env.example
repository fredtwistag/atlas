# ──────────────────────────────────────────────────────────────
# Atlas environment — copy to .env.local and fill in for backend work.
# The demo app runs with NONE of these set (data is in-memory).
# ──────────────────────────────────────────────────────────────

# Supabase (Postgres + RLS + storage) — docs/02-architecture.md §3
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres / Session-pooler connection string (Drizzle migrations + queries).
# The direct db.<ref>.supabase.co host is often IPv6-only; use the Session pooler
# URI from the Supabase dashboard (Connect → Session pooler).
# DATABASE_URL=

# Local ephemeral Postgres for adversarial RLS tests. Leave unset and
# embedded-postgres boots one automatically; set to reuse a system Postgres.
# DATABASE_URL_TEST=

# Stytch magic-link auth — docs/02-architecture.md §5.1
# STYTCH_PROJECT_ID=
# STYTCH_SECRET=

# Anthropic (Claude) — services/llm
# ANTHROPIC_API_KEY=

# Resend (email)
# RESEND_API_KEY=

# Inngest (workers)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
